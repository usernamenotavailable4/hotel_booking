<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>YOYO Pay — Secure Checkout</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    /* PREMIUM PURPLE GRADIENT */
    body {
      background: radial-gradient(circle at top, #3b0066, #1b002e, #0d0018);
    }

    /* Floating doodles */
    .doodle-shape {
      position: absolute;
      bottom: -60px;
      animation: floatUp linear infinite;
      font-weight: 700;
      opacity: 0.35;
      color: rgba(255, 255, 255, 0.5);
      pointer-events: none;
      user-select: none;
    }

    @keyframes floatUp {
      0% { transform: translateY(0); opacity: 0.4; }
      100% { transform: translateY(-150vh); opacity: 0; }
    }

    /* Tabs */
    .pay-tab {
      padding: 10px 18px;
      border-radius: 14px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.13);
      color: #eee;
      transition: 0.3s;
    }

    .active-tab {
      background: linear-gradient(to right, #f032c9, #7d1cff, #b44cff);
      border-color: rgba(255,255,255,0.4);
      box-shadow: 0 0 18px #8c2cff88;
    }

    .input-card {
      width: 100%;
      padding: 10px 14px;
      border-radius: 12px;
      background: rgba(0,0,0,0.4);
      border: 1px solid rgba(200,150,255,0.4);
      color: white;
    }

    .soft-btn {
      background: linear-gradient(to right, #f032c9, #7d1cff);
      box-shadow: 0 0 15px #8c2cff99;
    }

    /* DOODLES CONTAINER FIX */
    .animated-doodles {
      position: fixed;
      inset: 0;
      overflow: hidden;
      z-index: 0;
      pointer-events: none;
    }
  </style>
</head>

<body class="text-white font-sans min-h-screen overflow-x-hidden">

  <!-- FIXED DOODLE BACKGROUND -->
  <div class="animated-doodles"></div>

  <!-- CONTENT -->
  <div class="relative z-10">
    <!-- HEADER -->
    <header class="w-full backdrop-blur-xl bg-white/10 border-b border-purple-300/20 shadow-lg p-5 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-pink-400 to-purple-500 flex items-center justify-center font-bold text-xl shadow-md">Y</div>
        <h1 class="text-3xl font-extrabold bg-gradient-to-r from-pink-300 to-purple-200 bg-clip-text text-transparent">YOYO Pay</h1>
      </div>
      <div class="flex items-center gap-2 text-xs font-semibold text-gray-200">
        <span class="hidden md:block">🔒 128-bit SSL Encrypted</span>
        <span class="bg-green-500/20 px-3 py-1 rounded-xl border border-green-300/40 text-green-300">100% Secure Payment</span>
      </div>
    </header>

    <!-- PROGRESS -->
    <div class="max-w-4xl mx-auto mt-6 mb-4 px-6">
      <div class="w-full bg-white/10 h-2 rounded-full overflow-hidden">
        <div class="h-full bg-gradient-to-r from-fuchsia-500 to-purple-600 w-2/3"></div>
      </div>
      <p class="text-center text-xs mt-2 text-gray-200 tracking-wide">Step 2 of 3 — Payment</p>
    </div>

    <!-- MAIN -->
    <div class="max-w-6xl mx-auto px-4 py-6 grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- SUMMARY -->
      <aside class="bg-white/10 backdrop-blur-xl rounded-3xl border border-purple-300/20 shadow-xl p-6 h-max">
        <h2 class="text-xl font-bold text-pink-200 mb-4">Booking Summary</h2>

        <div class="space-y-3 text-sm text-gray-200">
          <div>
            <p class="font-semibold text-white text-base">Taj Mumbai Hotel</p>
            <p class="text-gray-300 text-xs">Premium Sea View Room</p>
          </div>

          <div class="grid grid-cols-2 gap-3 text-xs">
            <div class="bg-white/5 rounded-2xl p-3 border border-white/10">
              <p class="uppercase tracking-wide text-[11px] text-gray-300">Check-in</p>
              <p class="font-semibold text-white mt-1">14 Mar 2025</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-3 border border-white/10">
              <p class="uppercase tracking-wide text-[11px] text-gray-300">Check-out</p>
              <p class="font-semibold text-white mt-1">16 Mar 2025</p>
            </div>
          </div>

          <hr class="border-purple-200/20 my-2" />
          <div class="flex justify-between text-sm"><span>Room Price</span><span class="font-semibold">₹6400</span></div>
          <div class="flex justify-between text-sm"><span>Taxes & Fees</span><span class="font-semibold">₹768</span></div>
          <div class="flex justify-between text-sm"><span>Discount</span><span class="font-semibold text-green-300 bg-green-500/15 px-2 py-[2px] rounded-lg">- ₹0</span></div>

          <div class="mt-4 p-4 rounded-2xl bg-black/40 border border-purple-200/30 flex justify-between items-center">
            <span>Total Payable</span>
            <p class="text-3xl font-extrabold text-pink-200">₹7168</p>
          </div>
        </div>
      </aside>

      <!-- PAYMENT -->
      <section class="lg:col-span-2 bg-white/10 backdrop-blur-xl rounded-3xl border border-purple-300/20 shadow-xl p-8">
        <div class="flex gap-3 text-sm mb-6">
          <button data-tab="upi" class="pay-tab active-tab">UPI / QR</button>
          <button data-tab="card" class="pay-tab">Card</button>
          <button data-tab="netbanking" class="pay-tab">Netbanking</button>
        </div>

        <!-- UPI -->
        <div id="tab-upi" class="tab-panel">
          <div class="grid md:grid-cols-2 gap-8">

            <div class="bg-black/40 rounded-2xl p-6 border border-white/10 flex flex-col items-center text-center">
              <p class="text-gray-300 text-sm mb-3">Scan the QR using any UPI app</p>

              <div class="p-2 bg-white rounded-2xl shadow-inner w-48 h-48 flex items-center justify-center mb-4">
                <img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=upi://pay?pn=YOYOHotels&pa=yoyo@upi&am=7168" class="object-contain rounded-xl w-full h-full" />
              </div>
            </div>

            <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
              <p class="font-semibold mb-3 text-pink-200">Pay via UPI ID</p>
              <label class="text-xs text-gray-300">Enter your UPI ID</label>
              <input placeholder="example@upi" class="w-full mt-1 px-3 py-2 rounded-xl bg-black/40 border border-purple-200/50 text-white placeholder-gray-400" />
              <button onclick="startPayment('upi')" class="mt-5 w-full soft-btn py-3 rounded-xl font-semibold">Pay ₹7168 via UPI</button>
            </div>

          </div>
        </div>

        <!-- CARD -->
        <div id="tab-card" class="tab-panel hidden">
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 space-y-4">
            <p class="text-pink-200 font-semibold">Enter Card Details</p>
            <input placeholder="Card Number" class="input-card" />
            <div class="grid grid-cols-3 gap-3">
              <input placeholder="MM/YY" class="input-card" />
              <input placeholder="CVV" class="input-card" />
              <input placeholder="Card Holder Name" class="input-card" />
            </div>
            <button onclick="startPayment('card')" class="w-full soft-btn py-3 rounded-xl font-semibold">Pay ₹7168 Securely</button>
          </div>
        </div>

        <!-- NETBANKING -->
        <div id="tab-netbanking" class="tab-panel hidden">
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 space-y-4">
            <p class="text-pink-200 font-semibold">Select Bank</p>
            <select class="input-card bg-black/40 text-white">
              <option class="text-black">HDFC Bank</option>
              <option class="text-black">ICICI Bank</option>
              <option class="text-black">SBI</option>
              <option class="text-black">Axis Bank</option>
              <option class="text-black">Kotak Mahindra</option>
            </select>
            <button onclick="startPayment('netbanking')" class="w-full soft-btn py-3 rounded-xl font-semibold">Pay via NetBanking</button>
          </div>
        </div>
      </section>
    </div>
  </div>

  <!-- DOODLE SCRIPT FIXED -->
  <script>
    const doodleContainer = document.querySelector('.animated-doodles');

    // ALL DOODLES EXCEPT THE SECOND ONE (REMOVED ⬢)
    const shapes = ["◆","✦","✧","✪","●","◽"];

    for (let i = 0; i < 35; i++) {
      const doodle = document.createElement("div");
      doodle.innerText = shapes[Math.floor(Math.random() * shapes.length)];
      doodle.classList.add("doodle-shape");

      doodle.style.left = Math.random() * 100 + "vw";
      doodle.style.animationDuration = 10 + Math.random() * 18 + "s";
      doodle.style.fontSize = 22 + Math.random() * 45 + "px";

      doodleContainer.appendChild(doodle);
    }

    // Tabs
    document.querySelectorAll(".pay-tab").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".pay-tab").forEach(b => b.classList.remove("active-tab"));
        btn.classList.add("active-tab");
        document.querySelectorAll(".tab-panel").forEach(p => p.classList.add("hidden"));
        document.querySelector(`#tab-${btn.dataset.tab}`).classList.remove("hidden");
      });
    });

    function startPayment(method) {
      alert("Redirecting to payment: " + method.toUpperCase());
    }
  </script>

</body>
</html>
